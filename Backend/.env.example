# Copy this to .env and fill in your values

PORT=3001
NODE_ENV=production

# JWT Configuration
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=7d

# Admin Account (used during seeding)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@arunsjournal.com
ADMIN_PASSWORD=ChangeMeNow2025!

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Newsletter
NEWSLETTER_FROM_NAME=Arun's Journal
NEWSLETTER_FROM_EMAIL=hello@arunsjournal.com

# CORS
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://yourdomain.com